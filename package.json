{
    "name": "phonydata",
    "version": "2.2.0",
    "description": "Generate test data, based on casual's ideas and faker's data.",
    "main": "lib/index.js",
    "scripts": {
        "build": "rm -rf lib && tsc",
        "reinstall": "rm -rf package-lock.json node_modules && npm install",
        "test:ava": "ava",
        "test:lint": "eslint src",
        "test": "npm run test:lint && npm run test:ava"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/fidian/phonydata.git"
    },
    "keywords": [
        "phony",
        "fake",
        "data",
        "generate",
        "testing",
        "casual",
        "faker",
        "lorem",
        "random"
    ],
    "author": "Tyler Akins <fidian@rumkin.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/fidian/phonydata/issues"
    },
    "homepage": "https://github.com/fidian/phonydata#readme",
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@types/mersenne-twister": "^1.1.7",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "ava": "7.0.0",
        "eslint": "^10.1.0",
        "globals": "^17.4.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "mersenne-twister": "^1.1.0"
    },
    "sideEffects": false,
    "ava": {
        "extensions": [
            "ts"
        ],
        "files": [
            "src/**/*.spec.ts"
        ],
        "require": [
            "ts-node/register/transpile-only"
        ]
    }
}
